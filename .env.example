# Copy relevant values into firebase-functions/.env and app/web .env files.

# Firebase client config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Lemon Squeezy checkout share URL, e.g.
# https://your-store.lemonsqueezy.com/checkout/buy/YOUR_VARIANT_ID
LEMONSQUEEZY_CHECKOUT_URL=

# Set with:
# firebase functions:secrets:set LEMONSQUEEZY_WEBHOOK_SECRET
LEMONSQUEEZY_WEBHOOK_SECRET=
