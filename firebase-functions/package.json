{
  "name": "brainok-firebase-functions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "serve": "npm run build && firebase emulators:start --only auth,firestore,functions,storage",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.1",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
